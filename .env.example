# Supabase — Project Settings → API
# URL du projet (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Clé publique "anon" (jamais la service_role côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (optionnel) — monitoring d'erreurs. Sans DSN, Sentry est inerte.
# DSN public du projet Sentry (Settings → Projects → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=
# Upload des source maps au build (optionnel, CI/Vercel)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Monitoring d'erreurs — alertes mail via Resend
# Clé API Resend (resend.com → API Keys) — même compte que les emails transactionnels
RESEND_API_KEY=
# Email destinataire des alertes erreur/critique
MONITORING_ALERT_EMAIL=

# Webhook optionnel (Make, Zapier, n8n…) — en plus des alertes mail
MONITORING_WEBHOOK_URL=
