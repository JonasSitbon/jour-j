# Supabase — Project Settings → API
# URL du projet (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Clé publique "anon" (jamais la service_role côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (optionnel) — monitoring d'erreurs. Sans DSN, Sentry est inerte.
# DSN public du projet Sentry (Settings → Projects → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=
# Upload des source maps au build (optionnel, CI/Vercel)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Monitoring d'erreurs custom (optionnel)
# URL webhook déclenchée sur erreur/critique (Make.com, Zapier, n8n, Resend…)
MONITORING_WEBHOOK_URL=
# Email à inclure dans la payload du webhook (pour les automatisations)
MONITORING_ALERT_EMAIL=
